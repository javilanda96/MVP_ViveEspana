# ── Required in all environments ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key  # Settings → API → service_role (NOT anon key)

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development  # set to 'production' on the hosting platform

# ── Webhook secrets (REQUIRED in production, optional in development) ─────────
# Development: leave empty → permissive mode, all requests pass through.
# Production:  must be set — server refuses to start if either is missing.
#
# STRIPE_WEBHOOK_SECRET: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
#
# GHL_WEBHOOK_SECRET: any long random string you define.
# Configure GoHighLevel to send it as header:  X-GHL-Signature: <this value>
GHL_WEBHOOK_SECRET=

# ── Local database setup only (used by npm run db:setup:local) ────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pyme_integration
